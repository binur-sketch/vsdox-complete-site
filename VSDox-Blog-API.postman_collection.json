{
  "info": {
    "name": "VSDox Blog API",
    "description": "Complete API collection for the VSDox Blog backend. All protected routes require a Bearer token obtained from Login or Register.\n\nWorkflow:\n1. Run **Login** → token and session_token are auto-saved to collection variables\n2. All subsequent requests use {{token}} automatically\n3. When JWT expires, run **Refresh Token** to get a new one",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",         "value": "",  "type": "string" },
    { "key": "sessionToken",  "value": "",  "type": "string" },
    { "key": "postId",        "value": "1", "type": "string" },
    { "key": "postSlug",      "value": "my-first-post", "type": "string" },
    { "key": "categoryId",    "value": "1", "type": "string" },
    { "key": "tagId",         "value": "1", "type": "string" },
    { "key": "mediaId",       "value": "1", "type": "string" },
    { "key": "resetToken",    "value": "",  "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "Auth",
      "description": "Authentication, session management and account operations.",
      "item": [

        {
          "name": "Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const d = pm.response.json();",
                "  pm.collectionVariables.set('token', d.token);",
                "  pm.collectionVariables.set('sessionToken', d.session_token);",
                "  pm.test('Status 201', () => pm.response.to.have.status(201));",
                "  pm.test('Has token', () => pm.expect(d.token).to.be.a('string'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@vsdox.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"admin\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"session_token\": \"a1b2c3d4...\",\n  \"expires_at\": \"2024-01-01T01:00:00.000Z\",\n  \"idle_timeout\": 1800,\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin User\",\n    \"email\": \"admin@vsdox.com\",\n    \"role\": \"admin\",\n    \"avatar_url\": null,\n    \"bio\": null,\n    \"created_at\": \"2024-01-01T00:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "409 Email in use",
              "status": "Conflict",
              "code": 409,
              "body": "{ \"error\": \"Email already in use\" }"
            }
          ]
        },

        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const d = pm.response.json();",
                "  pm.collectionVariables.set('token', d.token);",
                "  pm.collectionVariables.set('sessionToken', d.session_token);",
                "  pm.test('Status 200', () => pm.response.to.have.status(200));",
                "  pm.test('Has JWT token', () => pm.expect(d.token).to.be.a('string'));",
                "  pm.test('Has session token', () => pm.expect(d.session_token).to.be.a('string'));",
                "  pm.test('Has user object', () => pm.expect(d.user).to.be.an('object'));",
                "  pm.test('No password_hash in response', () => pm.expect(d.user).to.not.have.property('password_hash'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vsdox.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"session_token\": \"a1b2c3d4e5f6...\",\n  \"expires_at\": \"2024-01-01T01:00:00.000Z\",\n  \"idle_timeout\": 1800,\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin User\",\n    \"email\": \"admin@vsdox.com\",\n    \"role\": \"admin\"\n  }\n}"
            },
            {
              "name": "401 Invalid credentials",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"error\": \"Invalid credentials\" }"
            }
          ]
        },

        {
          "name": "Refresh Token",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  const d = pm.response.json();",
                "  pm.collectionVariables.set('token', d.token);",
                "  pm.test('New JWT received', () => pm.expect(d.token).to.be.a('string'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_token\": \"{{sessionToken}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] }
          },
          "response": [
            {
              "name": "200 OK — new JWT",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"idle_timeout\": 1800\n}"
            },
            {
              "name": "401 Session expired",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"error\": \"Session expired. Please log in again.\", \"code\": \"SESSION_EXPIRED\" }"
            },
            {
              "name": "401 Session idle",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"error\": \"Idle timeout (30 min). Please log in again.\", \"code\": \"SESSION_IDLE\" }"
            },
            {
              "name": "401 Session not found",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"error\": \"Session not found. Please log in.\", \"code\": \"SESSION_NOT_FOUND\" }"
            }
          ]
        },

        {
          "name": "Logout",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  pm.collectionVariables.set('token', '');",
                "  pm.collectionVariables.set('sessionToken', '');",
                "  pm.test('Status 200', () => pm.response.to.have.status(200));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"message\": \"Logged out successfully\" }"
            }
          ]
        },

        {
          "name": "Get Me",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has user', () => pm.expect(pm.response.json().user).to.be.an('object'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth","me"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin User\",\n    \"email\": \"admin@vsdox.com\",\n    \"role\": \"admin\",\n    \"avatar_url\": null,\n    \"bio\": null,\n    \"created_at\": \"2024-01-01T00:00:00.000Z\"\n  }\n}"
            }
          ]
        },

        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin VSDox\",\n  \"bio\": \"Document intelligence expert.\",\n  \"avatar_url\": \"https://example.com/avatar.png\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/profile", "host": ["{{baseUrl}}"], "path": ["auth","profile"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"Admin VSDox\",\n    \"email\": \"admin@vsdox.com\",\n    \"role\": \"admin\",\n    \"avatar_url\": \"https://example.com/avatar.png\",\n    \"bio\": \"Document intelligence expert.\"\n  }\n}"
            }
          ]
        },

        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"Password123!\",\n  \"new_password\": \"NewPassword456!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth","change-password"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"message\": \"Password changed successfully\" }"
            },
            {
              "name": "401 Wrong current password",
              "status": "Unauthorized",
              "code": 401,
              "body": "{ \"error\": \"Current password is incorrect\" }"
            },
            {
              "name": "400 Too short",
              "status": "Bad Request",
              "code": 400,
              "body": "{ \"error\": \"New password must be at least 8 characters\" }"
            }
          ]
        },

        {
          "name": "Request Password Reset",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@vsdox.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth","forgot-password"] }
          },
          "response": [
            {
              "name": "200 OK (email sent or silently ignored)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"If the email exists, you will receive password reset instructions shortly.\",\n  \"expires_at\": \"2024-01-01T01:00:00.000Z\"\n}"
            },
            {
              "name": "429 Reset already pending",
              "status": "Too Many Requests",
              "code": 429,
              "body": "{ \"error\": \"A reset request is already pending. Please wait until the previous token expires before requesting again.\" }"
            }
          ]
        },

        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"NewPassword789!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth","reset-password"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"message\": \"Password reset successfully\" }"
            },
            {
              "name": "400 Invalid or expired token",
              "status": "Bad Request",
              "code": 400,
              "body": "{ \"error\": \"Invalid or expired reset token\" }"
            }
          ]
        }

      ]
    },

    {
      "name": "Posts — Public",
      "description": "No authentication required. These endpoints serve the public-facing blog.",
      "item": [

        {
          "name": "Get Published Posts",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has posts array', () => pm.expect(pm.response.json().posts).to.be.an('array'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts?page=1&limit=6&search=",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "page",   "value": "1",  "description": "Page number (default: 1)" },
                { "key": "limit",  "value": "6",  "description": "Posts per page (default: 10)" },
                { "key": "search", "value": "",   "description": "Search term (optional)", "disabled": true }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"posts\": [\n    {\n      \"id\": 1,\n      \"slug\": \"my-first-post\",\n      \"title\": \"My First Post\",\n      \"excerpt\": \"A short summary.\",\n      \"image\": \"http://localhost:5000/uploads/1700000000000-abc123.jpg\",\n      \"author\": \"Admin User\",\n      \"date\": \"2024-01-01T00:00:00.000Z\",\n      \"status\": \"published\",\n      \"categories\": [{ \"id\": 1, \"name\": \"Technology\" }],\n      \"tags\": [{ \"id\": 1, \"name\": \"nodejs\" }]\n    }\n  ],\n  \"total\": 1,\n  \"page\": 1,\n  \"limit\": 6\n}"
            }
          ]
        },

        {
          "name": "Get Post by Slug",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has body_html', () => pm.expect(pm.response.json()).to.have.property('body_html'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{postSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postSlug}}"]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"slug\": \"my-first-post\",\n  \"title\": \"My First Post\",\n  \"body\": \"# Hello\\n\\nWorld\",\n  \"body_html\": \"<h1>Hello</h1><p>World</p>\",\n  \"excerpt\": \"A short summary.\",\n  \"image\": \"http://localhost:5000/uploads/photo.jpg\",\n  \"author\": \"Admin User\",\n  \"date\": \"2024-01-01T00:00:00.000Z\",\n  \"status\": \"published\",\n  \"reading_time\": 1,\n  \"views\": 42,\n  \"categories\": [{ \"id\": 1, \"name\": \"Technology\" }],\n  \"tags\": [{ \"id\": 1, \"name\": \"nodejs\" }]\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{ \"error\": \"Post not found\" }"
            }
          ]
        }

      ]
    },

    {
      "name": "Posts — Admin",
      "description": "All endpoints require a valid Bearer token (admin role).",
      "item": [

        {
          "name": "Get All Posts (Admin)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has posts array', () => pm.expect(pm.response.json().posts).to.be.an('array'));",
                "const posts = pm.response.json().posts;",
                "if (posts.length > 0) {",
                "  pm.collectionVariables.set('postId', posts[0].id);",
                "  pm.collectionVariables.set('postSlug', posts[0].slug);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/admin/all?page=1&limit=100&status=&search=",
              "host": ["{{baseUrl}}"],
              "path": ["posts","admin","all"],
              "query": [
                { "key": "page",   "value": "1",   "description": "Page number" },
                { "key": "limit",  "value": "100", "description": "Posts per page" },
                { "key": "status", "value": "",    "description": "Filter: draft | published | scheduled | archived", "disabled": true },
                { "key": "search", "value": "",    "description": "Search term", "disabled": true }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"posts\": [\n    {\n      \"id\": 1,\n      \"slug\": \"my-first-post\",\n      \"title\": \"My First Post\",\n      \"status\": \"draft\",\n      \"excerpt\": \"A short summary.\",\n      \"image\": \"http://localhost:5000/uploads/photo.jpg\",\n      \"author\": \"Admin User\",\n      \"date\": null,\n      \"categories\": [{ \"id\": 1, \"name\": \"Technology\" }],\n      \"tags\": []\n    }\n  ],\n  \"total\": 1\n}"
            }
          ]
        },

        {
          "name": "Create Post",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const d = pm.response.json();",
                "  pm.collectionVariables.set('postId', d.post.id);",
                "  pm.collectionVariables.set('postSlug', d.post.slug);",
                "  pm.test('Status 201', () => pm.response.to.have.status(201));",
                "  pm.test('Post has id', () => pm.expect(d.post.id).to.be.a('number'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Post\",\n  \"body\": \"# Hello\\n\\nThis is the post body written in **markdown**.\",\n  \"excerpt\": \"A short summary of the post.\",\n  \"status\": \"draft\",\n  \"featured_image\": \"\",\n  \"featured_image_alt\": \"\",\n  \"meta_title\": \"\",\n  \"meta_description\": \"\",\n  \"category_ids\": [1],\n  \"tag_ids\": [1],\n  \"scheduled_at\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/posts/admin", "host": ["{{baseUrl}}"], "path": ["posts","admin"] }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Post created\",\n  \"post\": {\n    \"id\": 1,\n    \"slug\": \"my-first-post\",\n    \"title\": \"My First Post\",\n    \"status\": \"draft\",\n    \"body\": \"# Hello\\n\\nThis is the post body.\",\n    \"body_html\": \"<h1>Hello</h1><p>This is the post body.</p>\"\n  }\n}"
            }
          ]
        },

        {
          "name": "Update Post",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Updated Post Title\",\n  \"body\": \"# Updated\\n\\nUpdated body content.\",\n  \"excerpt\": \"Updated excerpt.\",\n  \"status\": \"draft\",\n  \"featured_image\": \"http://localhost:5000/uploads/photo.jpg\",\n  \"featured_image_alt\": \"A photo\",\n  \"meta_title\": \"SEO Title\",\n  \"meta_description\": \"SEO description under 160 chars.\",\n  \"category_ids\": [1],\n  \"tag_ids\": [1, 2],\n  \"scheduled_at\": null\n}"
            },
            "url": { "raw": "{{baseUrl}}/posts/admin/{{postId}}", "host": ["{{baseUrl}}"], "path": ["posts","admin","{{postId}}"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Post updated\",\n  \"post\": { \"id\": 1, \"slug\": \"my-updated-post-title\", \"title\": \"My Updated Post Title\", \"status\": \"draft\" }\n}"
            }
          ]
        },

        {
          "name": "Publish Post",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Status is published', () => pm.expect(pm.response.json().post.status).to.eql('published'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/posts/admin/{{postId}}/publish", "host": ["{{baseUrl}}"], "path": ["posts","admin","{{postId}}","publish"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Post published\",\n  \"post\": { \"id\": 1, \"status\": \"published\", \"date\": \"2024-01-01T00:00:00.000Z\" }\n}"
            }
          ]
        },

        {
          "name": "Withdraw Post",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Status is draft', () => pm.expect(pm.response.json().post.status).to.eql('draft'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/posts/admin/{{postId}}/withdraw", "host": ["{{baseUrl}}"], "path": ["posts","admin","{{postId}}","withdraw"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Post withdrawn to draft\",\n  \"post\": { \"id\": 1, \"status\": \"draft\" }\n}"
            }
          ]
        },

        {
          "name": "Delete Post",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has deleted id', () => pm.expect(pm.response.json().id).to.be.a('number'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/posts/admin/{{postId}}", "host": ["{{baseUrl}}"], "path": ["posts","admin","{{postId}}"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"message\": \"\\\"My First Post\\\" has been deleted\", \"id\": 1 }"
            }
          ]
        },

        {
          "name": "Get Post Preview (Draft)",
          "request": {
