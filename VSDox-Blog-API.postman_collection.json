    {
      "name": "Media",
      "description": "All endpoints require authentication. Upload is multipart/form-data. Delete checks for in-use images (409 if referenced in live posts).",
      "item": [

        {
          "name": "Upload Image",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  const d = pm.response.json();",
                "  pm.collectionVariables.set('mediaId', d.id);",
                "  pm.test('Status 201', () => pm.response.to.have.status(201));",
                "  pm.test('Has url', () => pm.expect(d.url).to.be.a('string'));",
                "  pm.test('Has filename', () => pm.expect(d.filename).to.be.a('string'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Image file — JPEG, PNG, WebP, GIF or SVG, max 10 MB"
                }
              ]
            },
            "url": { "raw": "{{baseUrl}}/media/upload", "host": ["{{baseUrl}}"], "path": ["media","upload"] }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"filename\": \"1700000000000-abc12345.jpg\",\n  \"original_name\": \"my-photo.jpg\",\n  \"url\": \"http://localhost:5000/uploads/1700000000000-abc12345.jpg\",\n  \"public_id\": \"1700000000000-abc12345.jpg\",\n  \"file_type\": \"image/jpeg\",\n  \"size\": 204800,\n  \"uploader_id\": 1,\n  \"uploaded_at\": \"2024-01-01T00:00:00.000Z\"\n}"
            },
            {
              "name": "400 No file provided",
              "status": "Bad Request",
              "code": 400,
              "body": "{ \"error\": \"No file provided\" }"
            },
            {
              "name": "400 Wrong file type",
              "status": "Bad Request",
              "code": 400,
              "body": "{ \"error\": \"Only image files are allowed (JPEG, PNG, WebP, GIF, SVG)\" }"
            }
          ]
        },

        {
          "name": "Get Media Library",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                "const media = pm.response.json();",
                "if (media.length > 0) pm.collectionVariables.set('mediaId', media[0].id);"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/media?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["media"],
              "query": [
                { "key": "page",  "value": "1",  "description": "Page number (default: 1)" },
                { "key": "limit", "value": "20", "description": "Items per page (default: 20)" }
              ]
            }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"filename\": \"1700000000000-abc12345.jpg\",\n    \"original_name\": \"my-photo.jpg\",\n    \"url\": \"http://localhost:5000/uploads/1700000000000-abc12345.jpg\",\n    \"file_type\": \"image/jpeg\",\n    \"size\": 204800,\n    \"uploader_name\": \"Admin User\",\n    \"uploaded_at\": \"2024-01-01T00:00:00.000Z\"\n  }\n]"
            }
          ]
        },

        {
          "name": "Check Media Usage",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has in_use field', () => pm.expect(pm.response.json()).to.have.property('in_use'));",
                "pm.test('Has used_in array', () => pm.expect(pm.response.json().used_in).to.be.an('array'));"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/media/{{mediaId}}/usage", "host": ["{{baseUrl}}"], "path": ["media","{{mediaId}}","usage"] }
          },
          "response": [
            {
              "name": "200 OK — not in use",
              "status": "OK",
              "code": 200,
              "body": "{ \"in_use\": false, \"used_in\": [] }"
            },
            {
              "name": "200 OK — in use",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"in_use\": true,\n  \"used_in\": [\n    { \"id\": 1, \"title\": \"My First Post\" },\n    { \"id\": 3, \"title\": \"Another Post\" }\n  ]\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{ \"error\": \"Media not found\" }"
            }
          ]
        },

        {
          "name": "Delete Media",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 or 409', () => {",
                "  pm.expect(pm.response.code).to.be.oneOf([200, 409]);",
                "});",
                "if (pm.response.code === 409) {",
                "  pm.test('Has MEDIA_IN_USE code', () => pm.expect(pm.response.json().code).to.eql('MEDIA_IN_USE'));",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/media/{{mediaId}}", "host": ["{{baseUrl}}"], "path": ["media","{{mediaId}}"] }
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{ \"message\": \"Media deleted\" }"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{ \"error\": \"Media not found\" }"
            },
            {
              "name": "409 Image In Use",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"Image is in use\",\n  \"code\": \"MEDIA_IN_USE\",\n  \"used_in\": [\n    { \"id\": 1, \"title\": \"My First Post\" }\n  ]\n}"
            }
          ]
        }

      ]
    }

