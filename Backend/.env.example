# Auth
JWT_SECRET=8f3c9d7b4a2e1f5c6b9d8a7e3f2c1b4a5d6e7f8c9a1b2c3d4e5f6a7b8c9d0e1
# JWT TTL — short rotation window (access ticket only)
JWT_TTL=15m

# Session idle timeout in seconds — user is logged out after this much inactivity
# Default: 1800 = 30 minutes
SESSION_IDLE_TIMEOUT=1800

# Absolute maximum session age in seconds — hard cap regardless of activity
# Default: 86400 = 24 hours
SESSION_MAX_AGE=86400

# Server Configuration
